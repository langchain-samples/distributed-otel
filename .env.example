# OpenAI API Key (for LangGraph and CrewAI agents)
OPENAI_API_KEY="your_openai_api_key_here"

# LangSmith Configuration (MUST match orchestrator!)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=paypal-multiagent


# OpenTelemetry Configuration
# Note: Endpoint must include /v1/traces for HTTP OTLP exporter
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel/v1/traces

# CrewAI MCP Server URL
CREWAI_MCP_URL=http://localhost:8000/mcp